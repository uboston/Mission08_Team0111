@using Microsoft.EntityFrameworkCore.Metadata.Internal
@model Mission08_Team0111.Models.Task
<!--Page with form to create a task-->
@{
    ViewData["Title"] = "Create Task";
}

<h2 class="text-center my-4">Add a New Task</h2>

<form asp-action="CreateTask" method="post" class="container w-50">
    <div class="mb-3">
        <label class="form-label">Task Name:</label>
        <input asp-for="TaskName" class="form-control" required />
        <span asp-validation-for="TaskName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Due Date:</label>
        <input asp-for="DueDate" type="date" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Quadrant:</label>
        <select asp-for="Quadrant" class="form-select" required>
            <option value="">Select Quadrant</option>
            <option value="1">Important / Urgent</option>
            <option value="2">Important / Not Urgent</option>
            <option value="3">Not Important / Urgent</option>
            <option value="4">Not Important / Not Urgent</option>
        </select>
        <span asp-validation-for="Quadrant" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Category:</label>
        <select asp-for="CategoryID" class="form-select" required>
          @foreach (Category c in ViewBag.Categories)
          {
              <option value="@c.CategoryID">@c.Name</option>
          }
        </select>
    </div>

    <div class="mb-3 form-check">
        <input type="checkbox" asp-for="Completed" class="form-check-input" />
        <label class="form-check-label">Completed</label>
    </div>

    <button type="submit" class="btn btn-success">Submit Task</button>

    <div asp-validation-summary="All"></div>
</form>