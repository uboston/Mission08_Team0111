@{
    ViewData["Title"] = "Home Page";
}

<h1>Stephen Covey&apos;s Time Management Matrix</h1>
<div class="container">
    <div class="row">
        <div class="col-2"></div>
        <div class="col">
            <p>Urgent</p>
        </div>
        <div class="col">
            <p>Not Urgent</p>
        </div>
    </div>
    <div class="row">
        <div class="col-2">
            <p>Important</p>
        </div>
        <div class="col">
            <h2>Quandrant 1</h2>
        </div>
        <div class="col">
            <h2>Quandrant 2</h2>
        </div>
    </div>
    <div class="row">
        <div class="col-2">
            <p>Not Important</p>
        </div>
        <div class="col">
            <h2>Quandrant 3</h2>
        </div>
        <div class="col">
            <h2>Quandrant 4</h2>
        </div>
    </div>
</div>

<button class="btn btn-primary" asp-controller="Home" asp-action="AddTask">Add Task</button>